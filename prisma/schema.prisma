generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String             @id @default(cuid())
  qfUserId          String             @unique
  refreshToken      String?
  firstName         String?
  lastName          String?
  email             String?
  khatmaPlans       KhatmaPlan[]
  settings          UserSettings?
  pushSubscriptions PushSubscription[]
  reminders         Reminder[]
  khatmaReminders   KhatmaReminder[]
  completedKhatmas Int              @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Reminder {
  id        String   @id @default(cuid())
  userId    String
  surahId   Int
  time      String // Format: "HH:mm"
  timezone  String // IANA timezone string, e.g., "America/New_York"
  days      Int[] // Array of days (0-6, where 0 is Sunday)
  isEnabled Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([time, isEnabled])
}

model KhatmaReminder {
  id        String   @id @default(cuid())
  userId    String   @unique
  time      String // Format: "HH:mm"
  timezone  String // IANA timezone string, e.g., "America/New_York"
  isEnabled Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([time, isEnabled])
}

model UserSettings {
  id                String            @id @default(uuid())
  userId            String            @unique
  reciterId         Int               @default(7)
  reciterName       String            @default("مشاري راشد العفاسي")
  volume            Float             @default(0.5)
  fontStyle         String            @default("uthmani")
  fontSize          Int               @default(3)
  ayahNumberStyle   String            @default("ayah-2")
  lastReadAt        DateTime?
  lastPlayedSurahId Int?
  lastPlayedAt      DateTime?
  athkarData        Json              @default("{}")
  athkarExpiration  DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  lastRead          Json?
  playHistory       PlayHistory[]
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  wishlistReciters  WishlistReciter[]
  wishlistSurahs    WishlistSurah[]

  @@index([userId])
}

model WishlistSurah {
  id                     String       @id @default(uuid())
  surahId                Int
  settingsId             String
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  englishName            String
  englishNameTranslation String
  mushafName             String
  numberOfAyahs          Int
  reciterId              Int
  reciterName            String
  revelationType         String
  shortName              String
  surahName              String
  url                    String
  mushafId               Int
  settings               UserSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)

  @@unique([settingsId, surahId, mushafId])
  @@index([settingsId])
  @@index([surahId])
}

model WishlistReciter {
  id           String       @id @default(uuid())
  reciterId    Int
  settingsId   String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  mushafId     Int
  mushafName   String
  reciterImage String
  reciterName  String
  settings     UserSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)

  @@unique([settingsId, reciterId, mushafId])
  @@index([settingsId])
  @@index([reciterId])
}

model PlayHistory {
  id                     String       @id @default(uuid())
  settingsId             String
  surahId                Int
  reciterId              Int
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  englishName            String
  englishNameTranslation String
  mushafId               Int
  mushafName             String
  numberOfAyahs          Int
  reciterName            String
  revelationType         String
  shortName              String
  surahName              String
  url                    String
  settings               UserSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)

  @@unique([settingsId, surahId, reciterId, mushafId])
  @@index([settingsId])
  @@index([settingsId, surahId])
  @@index([surahId])
}

model KhatmaPlan {
  id              String    @id @default(uuid())
  userId          String
  pagesPerDay     Int       @default(20)
  totalPages      Int       @default(604)
  startDate       DateTime  @default(now())
  targetEndDate   DateTime
  currentPage     Int       @default(1)
  completedPages  Int       @default(0)
  isActive        Boolean   @default(true)
  isCompleted     Boolean   @default(false)
  completedAt     DateTime?
  title           String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  pausedAt        DateTime?
  bookMarkIndex   Int?
  totalPausedDays Int       @default(0)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isActive])
}
